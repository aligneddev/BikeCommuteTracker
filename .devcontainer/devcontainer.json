{
  "name": "Bike Tracking - Full Stack",
  "build": {
    "dockerfile": "devcontainer.Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "NODE_ENV": "development"
  },
  "postCreateCommand": "dotnet dev-certs https --trust && dotnet restore BikeTracking.slnx && npm ci --prefix src/BikeTracking.Frontend && dotnet build BikeTracking.slnx",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime",
        "Ionide.Ionide-fsharp",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "csharpier.csharpier-vscode",
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "microsoft-aspire.aspire-vscode",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "dotnet.defaultSolutionOrFolder": "${workspaceFolder}/BikeTracking.slnx",
        "[csharp]": {
          "editor.defaultFormatter": "csharpier.csharpier-vscode",
          "editor.formatOnSave": true
        },
        "[fsharp]": {
          "editor.defaultFormatter": "Ionide.Ionide-fsharp",
          "editor.formatOnSave": true
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "eslint.validate": [
          "javascript",
          "typescript",
          "typescriptreact"
        ]
      }
    }
  },
  "remoteUser": "root",
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/usr/local/share/dotnet-tools:/root/.dotnet/tools"
  }
}
